# Release 2.5 auth abstraction.
# Server and middleware read a base64url JSON cookie named mishava_session.
# Shape:
# {
#   "user": { "id": "uuid", "email": "person@example.com", "roles": ["consumer"] },
#   "memberships": [{ "organizationId": "uuid", "roles": ["ngo_owner"] }]
# }
# Org routes also require mishava_current_org_id.
